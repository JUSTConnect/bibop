'get_internal_sensor_visibility_bonus': '''func get_internal_sensor_visibility_bonus(module_id: String) -> int:\n\treturn BipobModuleCatalogRef.get_internal_sensor_visibility_bonus(module_id)\n''',
'get_internal_cooling_value': '''func get_internal_cooling_value(module_id: String) -> int:\n\treturn BipobModuleCatalogRef.get_internal_cooling_value(module_id)\n''',
'get_internal_power_distribution': '''func get_internal_power_distribution(module_id: String) -> int:\n\treturn BipobModuleCatalogRef.get_internal_power_distribution(module_id)\n''',
'get_internal_power_ports': '''func get_internal_power_ports(module_id: String) -> int:\n\treturn BipobModuleCatalogRef.get_internal_power_ports(module_id)\n''',
