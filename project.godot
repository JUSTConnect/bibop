;   param=value ; assign values to parameters

config_version=5

[application]

config/name="bibop"
run/main_scene="uid://diphyupq6cob4"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

RuntimeNotifications="*res://scripts/ui/runtime/runtime_notification_layer.gd"
RuntimeHudRepair="*res://scripts/ui/runtime/runtime_hud_repair_service.gd"
MapConstructorInspectorStructure="*res://scripts/ui/map_constructor/map_constructor_inspector_structure_layer.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=768

[input]

